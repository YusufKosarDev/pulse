# Copy to .env and adjust if needed. Local development defaults.
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse_local_dev
POSTGRES_DB=pulse

# Optional: POST alert lifecycle events (alert-opened / alert-resolved) to
# this URL as JSON. Leave unset to disable webhook notifications.
#WEBHOOK_URL=http://host.docker.internal:9099/hook

# Optional: email the same lifecycle events. Both SMTP_HOST and ALERT_EMAIL_TO
# must be set to enable; SMTP_USER/SMTP_PASSWORD only if the server needs auth.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#ALERT_EMAIL_TO=ops@example.com
#ALERT_EMAIL_FROM=pulse@example.com
