# Production environment template. Copy to .env.prod ON THE SERVER and fill in
# real values. .env.prod is gitignored — never commit a filled-in copy.
#
#   cp .env.prod.example .env.prod
#   # then edit .env.prod and set a strong password

POSTGRES_USER=pulse
# Generate a strong random password on the server, e.g.:
#   openssl rand -base64 24
# Do NOT reuse the local development password.
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=pulse

# Notifications stay disabled for the demo. Leave these empty.
WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=pulse@localhost
